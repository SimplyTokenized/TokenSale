# TokenSale Deployment Configuration
# Copy this file to .env and fill in the values. NEVER commit .env to version control.

# ---- Contract parameters ----

# Base Token Address (ERC20 token to be sold; the TokenSale proxy must be granted MINTER_ROLE on it)
BASE_TOKEN=

# Payment Recipient Address (where payments are forwarded; use a multisig in production)
PAYMENT_RECIPIENT=

# Admin Address (receives DEFAULT_ADMIN_ROLE, ADMIN_ROLE, WHITELIST_ROLE and owns the ProxyAdmin;
# MUST be a multisig, ideally behind a timelock, in production)
ADMIN=

# ---- Network configuration ----

RPC_URL=http://localhost:8545
ETH_SEPOLIA_RPC=
TESTNET_RPC=
AVALANCHE_FUJI_RPC=
AVALANCHE_FUJI_VERIFIER_URL=
MAINNET_RPC=

# ---- Deployer credentials ----
# Prefer a hardware wallet or keystore over a raw private key for production deployments
# (see `forge script --help` for --ledger / --account options).

DEPLOYER=
DEPLOYER_KEY=
PRIVATE_KEY=

# ---- Verification ----

ETHERSCAN_API_KEY=
