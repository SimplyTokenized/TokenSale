{
  "name": "token-sale",
  "version": "1.0.0",
  "private": true,
  "description": "Upgradeable token sale contract with multiple payment tokens, ETH support, Chainlink oracle pricing, optional whitelisting, and configurable sale limits",
  "author": "SimplyTokenized",
  "license": "MIT",
  "scripts": {
    "setup": "forge install OpenZeppelin/openzeppelin-contracts-upgradeable OpenZeppelin/openzeppelin-foundry-upgrades OpenZeppelin/openzeppelin-contracts",
    "build": "forge build",
    "test": "forge clean && forge build && forge test --no-match-path \"test/SepoliaOracleFeeds.t.sol\"",
    "test:all": "forge clean && forge build && forge test",
    "test:oraclefeeds": "forge test --match-path test/SepoliaOracleFeeds.t.sol -vv",
    "test:fast": "forge test --no-match-path \"test/SepoliaOracleFeeds.t.sol\"",
    "test:gas": "forge test --no-match-path \"test/SepoliaOracleFeeds.t.sol\" --gas-report",
    "test:verbose": "forge test --no-match-path \"test/SepoliaOracleFeeds.t.sol\" -vv",
    "format": "forge fmt src/ test/ script/",
    "format:check": "forge fmt --check src/ test/ script/",
    "deploy:testnet": "forge script script/DeployTokenSale.s.sol:DeployTokenSale --private-key $DEPLOYER_KEY --broadcast --verify --rpc-url $TESTNET_RPC --etherscan-api-key $ETHERSCAN_API_KEY --sender $DEPLOYER",
    "deploy:fuji": "forge script script/DeployTokenSale.s.sol:DeployTokenSale --private-key $DEPLOYER_KEY --broadcast --verify --rpc-url $AVALANCHE_FUJI_RPC --etherscan-api-key $ETHERSCAN_API_KEY --verifier-url $AVALANCHE_FUJI_VERIFIER_URL --sender $DEPLOYER",
    "deploy:sepolia": "forge script script/DeployTokenSale.s.sol:DeployTokenSale --private-key $DEPLOYER_KEY --broadcast --verify --rpc-url $ETH_SEPOLIA_RPC --etherscan-api-key $ETHERSCAN_API_KEY --sender $DEPLOYER",
    "deploy:local": "forge script script/DeployTokenSale.s.sol:DeployTokenSale --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --broadcast --rpc-url http://localhost:8545 --sender 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
    "deploy:nodejs": "node deploy-nodejs.js",
    "anvil": "anvil",
    "anvil:fork": "anvil --fork-url $MAINNET_RPC",
    "slither": "slither .",
    "clean": "forge clean",
    "install:deps": "forge install OpenZeppelin/openzeppelin-contracts-upgradeable OpenZeppelin/openzeppelin-foundry-upgrades OpenZeppelin/openzeppelin-contracts",
    "update:deps": "forge update",
    "docgen": "forge doc --build --out docs",
    "docgen:serve": "forge doc --build --serve --open --out docs"
  },
  "keywords": [
    "solidity",
    "token-sale",
    "ico",
    "ido",
    "erc20",
    "blockchain",
    "ethereum",
    "avalanche",
    "foundry",
    "defi"
  ],
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "solc": "0.8.27"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
